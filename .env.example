# Clé API (la seule nécessaire)
ANTHROPIC_API_KEY=sk-ant-...

# Podcast
PODCAST_TITLE=Briefing matinal
PODCAST_DESCRIPTION=Briefing radio matinal francophone québécois, généré par IA.
PODCAST_BASE_URL=https://ton-serveur.com/podcast
PODCAST_AUTHOR=Ton nom

# Génération
CLAUDE_MODEL=claude-sonnet-4-6
