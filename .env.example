BRIEFING_FENETRE_HEURES=24

# TTS — voix disponibles (edge-tts, gratuit, sans compte) :
#   fr-CA-AntoineNeural  (voix masculine québécoise)
#   fr-CA-SylvieNeural   (voix féminine québécoise)
TTS_VOICE=fr-CA-AntoineNeural
